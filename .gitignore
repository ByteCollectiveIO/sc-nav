# Python
__pycache__/
*.py[cod]
.venv/

# Local tooling / OS
.claude/settings.local.json
.DS_Store
.pytest_cache/

# Build artifacts
*.zip

# Per-deployment runtime data, written by the server/watcher at run time.
# (The dataset cache poi/containers.json + poi/poi.json IS committed as an
# offline seed so a fresh clone runs and the tests pass.)
watcher/watcher_config.json
poi/custom_pois.json
poi/resource_nodes.json
poi/wildlife.json
poi/handles.json
poi/commodities.json
poi/ships.json
poi/items.json
poi/item_catalog.json
poi/item_attributes.json
poi/trade_terminals.json
poi/trade_prices.json
poi/watcher_tokens.json
poi/sc_nav.db
poi/sc_nav.db-wal
poi/sc_nav.db-shm
poi/branding/
# quantum_drives.json + quantum_profiles.json ARE committed (offline seed, like
# poi.json); the match report is a build artifact for eyeballing coverage only.
poi/quantum_match_report.txt
# blueprints.json IS committed (#25 feed); its sync report is a build artifact.
poi/blueprint_sync_report.txt
# locations.json IS committed (#28 wiki catalog); its sync report is a build artifact.
poi/locations_sync_report.txt

# Third-party reference data kept locally for development only — NOT committed.
# erkul.games content is CC BY-NC-ND 4.0; redistributing their compiled feed /
# calculator output would violate NoDerivatives/NonCommercial. We source quantum
# drive + fuel facts from CIG game data instead (see docs/cargo-hauling-planner.md).
docs/qdrives.json
docs/loadout.json

# Secrets / local env — list the FILE here, never the secret itself.
# Copy .env.example (tracked) to .env and fill in; .env never gets committed.
.env

# Ignore the impeccable stuff.
server/static/.impeccable/

# Local tooling + generated data — NOT app code, kept out of the repo:
# vendored Claude skills, impeccable design-review config/caches/critique
# snapshots, and the uexcorp scrape output dir. (The hand-written `deploy` skill
# and the CI workflows stay tracked — these ignore only the vendored/generated
# siblings.)
.claude/skills/impeccable/
.github/skills/
.github/hooks/
.impeccable/
output/
images/trade_route_planner.png
