# Python
__pycache__/
*.py[cod]
.venv/

# Local tooling / OS
.claude/settings.local.json
.DS_Store

# Build artifacts
*.zip

# Per-deployment runtime data, written by the server/watcher at run time.
# (The dataset cache poi/containers.json + poi/poi.json IS committed as an
# offline seed so a fresh clone runs and the tests pass.)
watcher/watcher_config.json
poi/custom_pois.json
poi/resource_nodes.json
poi/wildlife.json
poi/handles.json
poi/commodities.json

# Secrets / local env — list the FILE here, never the secret itself.
# The Cloudflare tunnel token goes inside .env (CLOUDFLARE_TUNNEL_TOKEN=...).
.env
