__pycache__/
*.py[cod]
.venv/

# Local tooling / OS
.claude/settings.local.json
.DS_Store

# Build artifacts
*.zip

# Per-deployment runtime data, written by the server/watcher at run time.
# (The dataset cache poi/containers.json + poi/poi.json IS committed as an
# offline seed so a fresh clone runs and the tests pass.)
watcher/watcher_config.json
poi/custom_pois.json
poi/resource_nodes.json
poi/wildlife.json
poi/handles.json
poi/commodities.json
poi/ships.json
poi/watcher_tokens.json
poi/sc_nav.db
poi/sc_nav.db-wal
poi/sc_nav.db-shm
poi/branding/

# Third-party reference data kept locally for development only — NOT committed.
# erkul.games content is CC BY-NC-ND 4.0; redistributing their compiled feed /
# calculator output would violate NoDerivatives/NonCommercial. We source quantum
# drive + fuel facts from CIG game data instead (see docs/cargo-hauling-planner.md).
docs/qdrives.json
docs/loadout.json

# Secrets / local env — list the FILE here, never the secret itself.
# The Cloudflare tunnel token goes inside .env (CLOUDFLARE_TUNNEL_TOKEN=...).
.env
