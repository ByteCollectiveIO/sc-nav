# Copy to .env and fill in for local `docker compose up`.
# In the Portainer git-stack deployment these are set in the stack's
# environment-variables UI instead — no .env file on the server.
# .env is gitignored; never commit real values.

# Discord OAuth app (Developer Portal -> your app -> OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# Discord server (guild) the org lives in; members of this guild may log in.
ORG_GUILD_ID=
# Optional: restrict login to holders of this role id (blank = any guild member).
ORG_MEMBER_ROLE_ID=
# Comma-separated Discord user ids granted the ADMIN panel.
ADMIN_IDS=

# Session cookie signing key — generate with: openssl rand -hex 32
SESSION_SECRET=
# "1" when serving over HTTPS (production), "0" for plain-HTTP local dev.
COOKIE_SECURE=

# Public base URL of the app, e.g. https://nav.example.com
SC_NAV_PUBLIC_URL=

# Cloudflare Tunnel connector token (Zero Trust dashboard) — used by the
# cloudflared sidecar in docker-compose.yml. Omit if you expose the app another way.
CLOUDFLARE_TUNNEL_TOKEN=
